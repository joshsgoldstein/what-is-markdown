---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = articles[0];
const rest = articles.slice(1);

const base = import.meta.env.BASE_URL;

function imgSrc(path: string) {
  if (!path) return path;
  return base + (path.startsWith('/') ? path.slice(1) : path);
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title="Lost In AI Land — Field Notes for the AI Age">
  <div class="page">

    {featured && (
      <a href={`${base}articles/${featured.slug}`} class="featured-card">
        {featured.data.image && (
          <div class="featured-image">
            <img src={imgSrc(featured.data.image)} alt={featured.data.title} loading="eager" />
          </div>
        )}
        <div class="featured-body">
          <div class="featured-tags">
            {featured.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <h2 class="featured-title">{featured.data.title}</h2>
          {featured.data.subtitle && <p class="featured-subtitle">{featured.data.subtitle}</p>}
          <p class="featured-desc">{featured.data.description}</p>
          <div class="featured-meta">
            <span>{formatDate(featured.data.date)}</span>
            <span class="cta">Read article →</span>
          </div>
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <>
        <div class="section-title">More Articles</div>
        <div class="article-list">
          {rest.map((article) => (
            <a href={`${base}articles/${article.slug}`} class="article-row">
              {article.data.image && (
                <div class="article-thumb">
                  <img src={imgSrc(article.data.image)} alt={article.data.title} loading="lazy" />
                </div>
              )}
              <div class="article-info">
                <div class="article-tags">
                  {article.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
                <div class="article-title">{article.data.title}</div>
                <div class="article-date">{formatDate(article.data.date)}</div>
              </div>
              <div class="article-cta">→</div>
            </a>
          ))}
        </div>
      </>
    )}

    <div class="footer">
      <div class="footer-left">Lost In AI Land</div>
      <div class="footer-right">lostinai.land</div>
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Featured Card ── */
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: var(--ink);
    margin-bottom: 40px;
    transition: border-color 0.15s, box-shadow 0.15s;
    min-height: 300px;
  }

  .featured-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(201, 79, 42, 0.1);
  }

  .featured-image {
    overflow: hidden;
    background: var(--border);
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-body {
    padding: 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: center;
  }

  .featured-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .featured-title {
    font-family: 'DM Serif Display', serif;
    font-size: 26px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    font-weight: 400;
  }

  .featured-subtitle {
    font-family: 'DM Serif Display', serif;
    font-size: 15px;
    font-style: italic;
    color: var(--muted);
    line-height: 1.4;
  }

  .featured-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .featured-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    margin-top: 4px;
  }

  .cta {
    color: var(--accent);
    font-size: 12px;
  }

  /* ── Article list ── */
  .article-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 16px;
  }

  .article-row {
    display: grid;
    grid-template-columns: 72px 1fr 24px;
    gap: 16px;
    align-items: center;
    padding: 14px 16px;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s;
  }

  .article-row:hover { border-color: var(--accent); }

  .article-thumb {
    width: 72px;
    height: 48px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--border);
    flex-shrink: 0;
  }

  .article-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .article-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .article-title {
    font-family: 'DM Serif Display', serif;
    font-size: 15px;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .article-date {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .article-cta {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-image { height: 200px; }
    .featured-body { padding: 20px 20px; }
    .featured-title { font-size: 22px; }
    .article-row { grid-template-columns: 60px 1fr; }
    .article-cta { display: none; }
  }
</style>
