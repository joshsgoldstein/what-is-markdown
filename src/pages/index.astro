---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const toSheetPath = (value: string) => `${value.replace(/^\/+|\/+$/g, '')}/`;

const cheatsheets = [
  {
    issue: '01',
    title: 'Markdown',
    subtitle: 'Cheatsheet',
    description: 'Headings, emphasis, lists, links, front matter, and why LLMs love Markdown.',
    href: 'markdown-cheatsheet',
  },
  {
    issue: '02',
    title: 'Git',
    subtitle: 'Cheatsheet',
    description: 'Essential commands, branching, commit metadata, and why AI agents live inside Git.',
    href: 'git-cheatsheet',
  },
  {
    issue: '03',
    title: 'BM25',
    subtitle: 'Cheatsheet',
    description: 'How BM25 ranks documents with IDF, saturation, and hybrid search best practices for RAG.',
    href: 'bm25',
  },
];

const recentArticles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title="AI Basics — Cheatsheet Series">
  <div class="page">

    <div class="header">
      <div class="header-left">
        <div class="series-tag">Lost In AI Land</div>
        <h1>AI Basics<br><em>Cheatsheets</em></h1>
        <p class="subtitle">Quick references for the tools that matter.</p>
      </div>
      <div class="header-right">
        <div class="big-label">Field Notes<br>for the<br>AI Age</div>
      </div>
    </div>

    <div class="section-title">All Issues</div>

    <div class="sheet-grid">
      {cheatsheets.map((sheet) => (
        <a href={toSheetPath(sheet.href)} class="sheet-card">
          <div class="sheet-issue">Issue {sheet.issue}</div>
          <div class="sheet-title">
            {sheet.title}<br /><em>{sheet.subtitle}</em>
          </div>
          <p class="sheet-desc">{sheet.description}</p>
          <div class="sheet-cta">Open →</div>
        </a>
      ))}
    </div>

    <div class="section-title">Recent Articles</div>

    <div class="article-list">
      {recentArticles.map((article) => (
        <a href={`/articles/${article.slug}`} class="article-row">
          {article.data.image && (
            <div class="article-thumb">
              <img src={article.data.image} alt={article.data.title} loading="lazy" />
            </div>
          )}
          <div class="article-info">
            <div class="article-row-tags">
              {article.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="article-row-title">{article.data.title}</div>
            <div class="article-row-date">{formatDate(article.data.date)}</div>
          </div>
          <div class="article-row-cta">Read →</div>
        </a>
      ))}
    </div>

    <a href="/articles" class="all-articles-link">View all articles →</a>

    <div class="footer">
      <div class="footer-left">Lost In AI Land</div>
      <div class="footer-right">AI Basics Series · lostinai.land</div>
    </div>

  </div>
</BaseLayout>

<style>
  .sheet-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 40px;
  }

  @media (max-width: 600px) {
    .sheet-grid { grid-template-columns: 1fr; }
  }

  .sheet-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 28px 24px;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .sheet-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 12px rgba(201, 79, 42, 0.08);
  }

  .sheet-issue {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tag);
    background: var(--tag-bg);
    padding: 4px 10px;
    border-radius: 3px;
    width: fit-content;
  }

  .sheet-title {
    font-family: 'DM Serif Display', serif;
    font-size: 32px;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .sheet-title em {
    color: var(--accent);
    font-style: italic;
  }

  .sheet-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
  }

  .sheet-cta {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  /* ── Articles ── */
  .article-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 16px;
  }

  .article-row {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 14px 16px;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .article-row:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 8px rgba(201, 79, 42, 0.07);
  }

  .article-thumb {
    width: 80px;
    height: 54px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--border);
    flex-shrink: 0;
  }

  .article-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .article-row-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tag);
    background: var(--tag-bg);
    padding: 2px 7px;
    border-radius: 3px;
  }

  .article-row-title {
    font-family: 'DM Serif Display', serif;
    font-size: 15px;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .article-row-date {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .article-row-cta {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .all-articles-link {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.06em;
    margin-bottom: 40px;
  }

  .all-articles-link:hover { text-decoration: underline; }

  @media (max-width: 600px) {
    .article-row {
      grid-template-columns: 64px 1fr;
    }
    .article-row-cta { display: none; }
  }
</style>
