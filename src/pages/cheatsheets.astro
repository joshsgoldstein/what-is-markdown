---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/?$/, '/');

const sheets = [
  {
    issue: '01',
    title: 'Markdown',
    subtitle: 'Cheatsheet',
    description: 'Headings, emphasis, lists, links, front matter, and why LLMs love Markdown.',
    href: `${base}markdown-cheatsheet`,
  },
  {
    issue: '02',
    title: 'Git',
    subtitle: 'Cheatsheet',
    description: 'Essential commands, branching, commit metadata, and why AI agents live inside Git.',
    href: `${base}git-cheatsheet`,
  },
  {
    issue: '03',
    title: 'BM25',
    subtitle: 'Cheatsheet',
    description: 'How BM25 ranks documents with IDF, saturation, and hybrid search best practices for RAG.',
    href: `${base}bm25`,
  },
  {
    issue: '04',
    title: 'CLI',
    subtitle: 'Cheatsheet',
    description: 'OS basics, product CLIs, pipes, and why AI agents were born to live in the terminal.',
    href: `${base}cli-cheatsheet`,
  },
];
---

<BaseLayout
  title="Cheatsheets — Lost In AI Land"
  description="Quick-reference guides for the tools that matter in the AI age."
>
  <div class="page">

    <div class="page-header">
      <h1>Cheat<em>sheets</em></h1>
      <p class="page-desc">Quick-reference guides for the tools that matter.</p>
    </div>

    <div class="section-title">All Issues</div>

    <div class="sheet-grid">
      {sheets.map((sheet) => (
        <a href={sheet.href} class="sheet-card">
          <div class="sheet-issue">Issue {sheet.issue}</div>
          <div class="sheet-title">{sheet.title}<br /><em>{sheet.subtitle}</em></div>
          <p class="sheet-desc">{sheet.description}</p>
          <div class="sheet-cta">Open →</div>
        </a>
      ))}
    </div>

    <div class="footer">
      <div class="footer-left">Lost In AI Land</div>
      <div class="footer-right">lostinai.land</div>
    </div>

  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 40px;
  }

  .page-header h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 42px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .page-desc {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .sheet-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 48px;
  }

  @media (max-width: 600px) {
    .sheet-grid { grid-template-columns: 1fr; }
  }

  .sheet-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 28px 24px;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .sheet-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 12px rgba(201, 79, 42, 0.08);
  }

  .sheet-issue {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tag);
    background: var(--tag-bg);
    padding: 4px 10px;
    border-radius: 3px;
    width: fit-content;
  }

  .sheet-title {
    font-family: 'DM Serif Display', serif;
    font-size: 32px;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .sheet-title em { color: var(--accent); font-style: italic; }

  .sheet-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
  }

  .sheet-cta {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.06em;
    margin-top: 4px;
  }
</style>
