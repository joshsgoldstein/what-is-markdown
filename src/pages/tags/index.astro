---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/?$/, '/');

const tagCounts: Record<string, number> = {};
for (const article of articles) {
  for (const tag of article.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}
const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags — Lost In AI Land" description="Browse articles by tag.">
  <div class="page">

    <div class="section-title">All Tags</div>

    <div class="tag-grid">
      {tags.map(([tag, count]) => (
        <a href={`${base}tags/${tag}`} class="tag-card">
          <span class="tag-name">{tag}</span>
          <span class="tag-count">{count}</span>
        </a>
      ))}
    </div>

    <div class="footer">
      <div class="footer-left">Lost In AI Land</div>
      <div class="footer-right">lostinai.land</div>
    </div>

  </div>
</BaseLayout>

<style>
  .tag-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 48px;
  }

  .tag-card {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 10px 16px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s;
  }

  .tag-card:hover { border-color: var(--accent); }

  .tag-name {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tag);
  }

  .tag-count {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    background: var(--border);
    padding: 1px 7px;
    border-radius: 10px;
  }
</style>
