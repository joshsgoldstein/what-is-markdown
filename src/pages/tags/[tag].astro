---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const tags = [...new Set(articles.flatMap((a) => a.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag, articles: articles.filter((a) => a.data.tags.includes(tag)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()) },
  }));
}

const { tag, articles } = Astro.props;
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/?$/, '/');

function imgSrc(path: string) {
  if (!path) return path;
  return base + (path.startsWith('/') ? path.slice(1) : path);
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title={`#${tag} — Lost In AI Land`} description={`Articles tagged with ${tag}.`}>
  <div class="page">

    <a href={`${base}tags`} class="back-link">← All Tags</a>

    <div class="section-title">#{tag}</div>

    <div class="article-list">
      {articles.map((article) => (
        <a href={`${base}articles/${article.slug}`} class="article-row">
          {article.data.image && (
            <div class="article-thumb">
              <img src={imgSrc(article.data.image)} alt={article.data.title} loading="lazy" />
            </div>
          )}
          <div class="article-info">
            <div class="article-tags">
              {article.data.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <div class="article-title">{article.data.title}</div>
            <p class="article-desc">{article.data.description}</p>
            <div class="article-date">{formatDate(article.data.date)}</div>
          </div>
          <div class="article-cta">→</div>
        </a>
      ))}
    </div>

    <div class="footer">
      <div class="footer-left">Lost In AI Land</div>
      <div class="footer-right"><a href={`${base}tags`}>← All Tags</a></div>
    </div>

  </div>
</BaseLayout>

<style>
  .article-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 16px;
  }

  .article-row {
    display: grid;
    grid-template-columns: 72px 1fr 24px;
    gap: 16px;
    align-items: center;
    padding: 14px 16px;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s;
  }

  .article-row:hover { border-color: var(--accent); }

  .article-thumb {
    width: 72px;
    height: 48px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--border);
    flex-shrink: 0;
  }

  .article-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .article-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .article-title {
    font-family: 'DM Serif Display', serif;
    font-size: 15px;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .article-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-date {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .article-cta {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--accent);
  }

  .footer-right a {
    color: var(--muted);
    text-decoration: none;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  .footer-right a:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .article-row { grid-template-columns: 60px 1fr; }
    .article-cta { display: none; }
  }
</style>
